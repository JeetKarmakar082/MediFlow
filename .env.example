SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (required for WebSockets + Celery)
REDIS_HOST=127.0.0.1
REDIS_URL=redis://127.0.0.1:6379/0

# OpenAI (optional, not used by default)
OPENAI_API_KEY=

# Google Gemini (free tier — recommended)
GEMINI_API_KEY=your-gemini-key-here

# Twilio SMS (optional — logs to console if not set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PostgreSQL (optional — uses SQLite by default)
# DB_NAME=hospital_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
